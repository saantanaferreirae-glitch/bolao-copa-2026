      <div style={{display:"flex",gap:6,marginBottom:10,overflowX:"auto",paddingBottom:4}}>
        {[["hoje","📅 Hoje"],["brasil","🇧🇷 Brasil"],["grupos","🌍 Grupos"],["mata","⚔️ Mata"]].map(([id,label])=>(
          <button key={id} onClick={()=>setAba(id)} style={{
            flexShrink:0,padding:"8px 12px",border:"none",borderRadius:10,
            fontWeight:700,fontSize:"0.75rem",cursor:"pointer",
            background:aba===id?"#FFDF00":"rgba(255,255,255,0.15)",
            color:aba===id?"#002776":"#fff",whiteSpace:"nowrap"
          }}>{label}</button>
        ))}
      </div>

      {/* SUB FILTRO GRUPOS */}
      {aba==="grupos"&&(
        <div style={{display:"flex",gap:5,marginBottom:10,overflowX:"auto",paddingBottom:4}}>
          {GRUPOS_FASE.map(g=>(
            <button key={g} onClick={()=>setGrupoFiltro(g)} style={{
              flexShrink:0,width:36,height:36,border:"none",borderRadius:8,
              fontWeight:700,fontSize:"0.78rem",cursor:"pointer",
              background:(grupoFiltro||"A")===g?"#FFDF00":"rgba(255,255,255,0.2)",
              color:(grupoFiltro||"A")===g?"#002776":"#fff"
            }}>{g}</button>
          ))}
        </div>
      )}

      {/* INFO ABA */}
      {aba==="hoje"&&(
        <div style={{color:"#cfe8ff",fontSize:"0.72rem",marginBottom:8,textAlign:"center"}}>
          Quarta, 17 de junho · {jgs.length} jogos
        </div>
      )}

      {/* LISTA DE JOGOS */}
      {loading?(
        <div style={{textAlign:"center",color:"#cfe8ff",padding:40}}>Carregando...</div>
      ):jgs.length===0?(
        <div style={{textAlign:"center",color:"#cfe8ff",padding:40,fontSize:"0.85rem"}}>Nenhum jogo nesta aba</div>
      ):jgs.map(jogo=>{
        const d=dados[jogo.id]||{};
        const resultado=d.resultado;
        const meuPalpite=d[usuario];
        const palpiteOutro=d[outro];
        const minhaCalc=calcPts(meuPalpite,resultado);
        const outroCalc=calcPts(palpiteOutro,resultado);
        const meuStatus=statusBox(meuPalpite,resultado);
        const outroStatus=statusBox(palpiteOutro,resultado);
        const jForm=form[jogo.id]||{};
        const rForm=resForm[jogo.id]||{};
        const eHoje=jogo.data.startsWith(HOJE);

        return (
          <div key={jogo.id} style={{background:"#fff",borderRadius:14,padding:13,marginBottom:10,boxShadow:"0 2px 10px rgba(0,0,0,0.12)",borderLeft:resultado?"4px solid #009C3B":eHoje?"4px solid #FFDF00":"4px solid transparent"}}>

            <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:9}}>
              <div>
                <div style={{fontWeight:700,fontSize:"0.87rem",color:"#002776",lineHeight:1.3}}>{jogo.nome}</div>
                <div style={{fontSize:"0.68rem",color:"#888",marginTop:2}}>Grupo {jogo.grupo} · {jogo.data}{eHoje&&!resultado?<span style={{marginLeft:6,background:"#FFDF00",color:"#002776",borderRadius:10,padding:"1px 6px",fontSize:"0.6rem",fontWeight:700}}>HOJE</span>:null}</div>
              </div>
              {resultado&&(
                <span style={{background:"#009C3B",color:"#fff",borderRadius:20,padding:"2px 9px",fontSize:"0.72rem",fontWeight:700,marginLeft:6,whiteSpace:"nowrap"}}>
                  ✔ {resultado.g1}–{resultado.g2}
                </span>
              )}
            </div>

            {resultado?(
              <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:7}}>
                {[{player:usuario,palpite:meuPalpite,calc:minhaCalc,status:meuStatus},{player:outro,palpite:palpiteOutro,calc:outroCalc,status:outroStatus}].map(({player,palpite,calc,status})=>(
                  <div key={player} style={{borderRadius:9,padding:9,textAlign:"center",...ST[status]}}>
                    <div style={{fontSize:"0.65rem",fontWeight:700,color:"#555",textTransform:"uppercase",marginBottom:3}}>{NOMES[player]}</div>
                    <div style={{fontWeight:900,fontSize:"1.5rem",color:"#002776",letterSpacing:2}}>{palpite?`${palpite.g1}–${palpite.g2}`:"?–?"}</div>
                    <div style={{fontSize:"0.68rem",fontWeight:700,color:"#555",marginTop:2}}>{calc.pts>0?`+${calc.pts}pts ✨`:"0pts 😔"}</div>
                    {palpite?.goleador&&<div style={{fontSize:"0.6rem",color:"#777",marginTop:1}}>⚽ {palpite.goleador}</div>}
                    {calc.itens.length>0&&<div style={{fontSize:"0.58rem",color:"#009C3B",marginTop:2}}>{calc.itens.join(" · ")}</div>}
                  </div>
                ))}
              </div>
            ):(
              <div>
                <div style={{background:`${CORES[usuario]}11`,borderRadius:9,padding:10,marginBottom:7,border:`2px solid ${CORES[usuario]}33`}}>
                  <div style={{fontSize:"0.68rem",fontWeight:700,color:CORES[usuario],marginBottom:7}}>SEU PALPITE</div>
                  <div style={{display:"flex",gap:5,alignItems:"center",marginBottom:7,flexWrap:"wrap"}}>
                    <input type="number" min="0" max="20" placeholder="0" value={jForm.g1??meuPalpite?.g1??""} onChange={e=>setForm(f=>({...f,[jogo.id]:{...f[jogo.id],g1:e.target.value}}))}
                      style={{width:44,height:40,borderRadius:7,border:`2px solid ${CORES[usuario]}`,textAlign:"center",fontSize:"1.1rem",fontWeight:700,color:"#002776",outline:"none"}} />
                    <span style={{fontWeight:700,color:"#aaa"}}>×</span>
                    <input type="number" min="0" max="20" placeholder="0" value={jForm.g2??meuPalpite?.g2??""} onChange={e=>setForm(f=>({...f,[jogo.id]:{...f[jogo.id],g2:e.target.value}}))}
                      style={{width:44,height:40,borderRadius:7,border:`2px solid ${CORES[usuario]}`,textAlign:"center",fontSize:"1.1rem",fontWeight:700,color:"#002776",outline:"none"}} />
                    <input type="text" placeholder="⚽ Goleador" value={jForm.goleador??meuPalpite?.goleador??""} onChange={e=>setForm(f=>({...f,[jogo.id]:{...f[jogo.id],goleador:e.target.value}}))}
                      style={{flex:1,minWidth:80,height:40,borderRadius:7,border:"2px solid #ddd",padding:"0 8px",fontSize:"0.8rem",outline:"none"}} />
                  </div>
                  <button onClick={()=>salvarPalpite(jogo.id)} disabled={salvando[jogo.id]} style={{width:"100%",padding:"8px",background:CORES[usuario],color:"#fff",border:"none",borderRadius:7,fontWeight:700,fontSize:"0.82rem",cursor:"pointer",opacity:salvando[jogo.id]?0.7:1}}>
                    {salvando[jogo.id]?"Salvando...":meuPalpite?"✏️ Atualizar":"💾 Salvar palpite"}
                  </button>
                </div>

                <div style={{background:"#f8f8f8",borderRadius:9,padding:"8px 10px",border:"2px solid #eee",display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                  <div style={{fontSize:"0.68rem",fontWeight:700,color:"#888"}}>{NOMES[outro]}</div>
                  {palpiteOutro?(
                    <div style={{display:"flex",alignItems:"center",gap:8}}>
                      <span style={{fontWeight:900,fontSize:"1.05rem",color:"#002776",letterSpacing:2}}>{palpiteOutro.g1}–{palpiteOutro.g2}</span>
                      {palpiteOutro.goleador&&<span style={{fontSize:"0.68rem",color:"#777"}}>⚽ {palpiteOutro.goleador}</span>}
                    </div>
                  ):(
                    <span style={{fontSize:"0.72rem",color:"#bbb"}}>⏳ aguardando...</span>
                  )}
                </div>

                <button onClick={()=>setResultadoAberto(r=>({...r,[jogo.id]:!r[jogo.id]}))}
                  style={{width:"100%",padding:7,background:"#002776",color:"#fff",border:"none",borderRadius:7,fontSize:"0.75rem",fontWeight:600,cursor:"pointer"}}>
                  🏁 Entrar resultado real
                </button>

                {resultadoAberto[jogo.id]&&(
                  <div style={{background:"#f0f4ff",borderRadius:9,padding:10,marginTop:7}}>
                    <div style={{fontSize:"0.68rem",fontWeight:700,color:"#555",marginBottom:7}}>RESULTADO REAL</div>
                    <div style={{display:"flex",gap:5,alignItems:"center",marginBottom:7,flexWrap:"wrap"}}>
                      <input type="number" min="0" max="20" placeholder="0" value={rForm.g1??""} onChange={e=>setResForm(f=>({...f,[jogo.id]:{...f[jogo.id],g1:e.target.value}}))}
                        style={{width:44,height:40,borderRadius:7,border:"2px solid #002776",textAlign:"center",fontSize:"1.1rem",fontWeight:700,outline:"none"}} />
                      <span style={{fontWeight:700,color:"#aaa"}}>×</span>
                      <input type="number" min="0" max="20" placeholder="0" value={rForm.g2??""} onChange={e=>setResForm(f=>({...f,[jogo.id]:{...f[jogo.id],g2:e.target.value}}))}
                        style={{width:44,height:40,borderRadius:7,border:"2px solid #002776",textAlign:"center",fontSize:"1.1rem",fontWeight:700,outline:"none"}} />
                      <input type="text" placeholder="⚽ Goleador real" value={rForm.goleador??""} onChange={e=>setResForm(f=>({...f,[jogo.id]:{...f[jogo.id],goleador:e.target.value}}))}
                        style={{flex:1,minWidth:80,height:40,borderRadius:7,border:"2px solid #ddd",padding:"0 8px",fontSize:"0.8rem",outline:"none"}} />
                    </div>
                    <button onClick={()=>salvarResultado(jogo.id)} style={{width:"100%",padding:8,background:"#FFDF00",color:"#002776",border:"none",borderRadius:7,fontWeight:700,fontSize:"0.82rem",cursor:"pointer"}}>
                      ✅ Confirmar resultado
                    </button>
                  </div>
                )}
              </div>
            )}
          </div>
        );
      })}

      <div style={{textAlign:"center",color:"rgba(255,255,255,0.35)",fontSize:"0.62rem",marginTop:12,paddingBottom:20}}>
        Sincroniza a cada 10s · {JOGOS.length} jogos cadastrados ⚡
      </div>
    </div>
  );
}

