function calcPts(palpite, resultado) {
  if (!palpite || !resultado) return { pts: 0, itens: [] };
  const pg1 = parseInt(palpite.g1)||0, pg2 = parseInt(palpite.g2)||0;
  const rg1 = parseInt(resultado.g1)||0, rg2 = parseInt(resultado.g2)||0;
  let pts = 0; const itens = [];
  if (pg1===rg1 && pg2===rg2) { pts+=5; itens.push("🎯+5"); }
  else {
    const pv=pg1>pg2?1:pg1<pg2?2:0, rv=rg1>rg2?1:rg1<rg2?2:0;
    if (pv===rv) { pts+=2; itens.push("✅+2"); }
  }
  if (pg1+pg2===rg1+rg2) { pts+=1; itens.push("🔢+1"); }
  const gl=(resultado.goleador||"").trim().toLowerCase();
  const pg=(palpite.goleador||"").trim().toLowerCase();
  if (gl&&pg&&gl===pg) { pts+=1; itens.push("⚽+1"); }
  return { pts, itens };
}

function statusBox(palpite, resultado) {
  if (!resultado||!palpite) return "pending";
  const pg1=parseInt(palpite.g1)||0,pg2=parseInt(palpite.g2)||0;
  const rg1=parseInt(resultado.g1)||0,rg2=parseInt(resultado.g2)||0;
  if (pg1===rg1&&pg2===rg2) return "exact";
  const pv=pg1>pg2?1:pg1<pg2?2:0,rv=rg1>rg2?1:rg1<rg2?2:0;
  return pv===rv?"winner":"wrong";
}

